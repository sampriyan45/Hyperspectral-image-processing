        "CV_FOLDS = 3\n",
        "GROUP_INIT = 12\n",
        "GROUP_BO_ITERS = 15\n",
        "\n",
        "def proxy_bands(groups):\n",
        "    out = []\n",
        "    for g in groups:\n",
        "        out.extend(sorted(groups_orig[g], key=lambda b: mi[b], reverse=True)[:3])\n",
        "    return sorted(set(out))[:TARGET_K]\n",
        "\n",
        "def eval_group_mask(mask):\n",
        "    groups = np.where(mask)[0]\n",
        "    if len(groups) == 0:\n",
        "        return 1.0\n",
        "\n",
        "    bands = proxy_bands(groups)\n",
        "\n",
        "    clf = make_pipeline(\n",
        "        StandardScaler(),\n",
        "        LinearSVC(C=0.1, max_iter=3000, dual=False)\n",
        "    )\n",
        "\n",
        "6+\n",
        "    acc = cross_val_score(\n",
        "        clf, X_train[:, bands], y_train,\n",
        "        cv=CV_FOLDS, scoring=\"accuracy\", n_jobs=-1\n",
        "    ).mean()\n",
        "\n",
        "    return 1.0 - acc\n",
        "\n",
        "def random_group_masks(N, k):\n",
        "    masks = []\n",
        "    for _ in range(N):\n",
        "        m = np.zeros(n_groups, dtype=int)\n",
        "        m[np.random.choice(n_groups, k, replace=False)] = 1\n",
        "        masks.append(m)\n",
        "    return masks\n",
        "\n",
        "K_g = min(6, max(3, n_groups // 2))\n",
        "obs_X, obs_y = [], []\n",
        "\n",
        "for m in random_group_masks(GROUP_INIT, K_g):\n",
        "    obs_X.append(m.astype(float))\n",
        "    obs_y.append(eval_group_mask(m))\n",
        "\n",
        "gpr = GaussianProcessRegressor(\n",
        "    kernel=C(1.0) * RBF() + WhiteKernel(1e-3),\n",
        "    normalize_y=True\n",
        ")\n",
        "\n",
        "best_l1 = []\n",
        "\n",
        "for it in range(GROUP_BO_ITERS):\n",
        "    gpr.fit(np.array(obs_X), np.array(obs_y))\n",
        "    cands = random_group_masks(250, K_g)\n",
        "    mu, sigma = gpr.predict(np.array(cands), return_std=True)\n",
        "\n",
        "    Z = (min(obs_y) - mu) / (sigma + 1e-9)\n",
        "    ei = (min(obs_y) - mu) * norm.cdf(Z) + sigma * norm.pdf(Z)\n",
        "\n",
        "    idx = np.argmax(ei)\n",
        "    obs_X.append(cands[idx].astype(float))\n",
        "    obs_y.append(eval_group_mask(cands[idx]))\n",
        "\n",
        "    best_l1.append(min(obs_y))\n",
        "    print(f\"L1 Iter {it+1}, Best Loss: {best_l1[-1]:.4f}\")\n",
        "\n",
        "best_group_mask = obs_X[np.argmin(obs_y)]\n",
        "best_groups = np.where(best_group_mask)[0]\n",
        "\n",
