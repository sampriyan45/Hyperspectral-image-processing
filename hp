        "import numpy as np\n",
        "from scipy.stats import norm\n",
        "from sklearn.svm import LinearSVC\n",
        "from sklearn.pipeline import make_pipeline\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.model_selection import cross_val_score\n",
        "from sklearn.gaussian_process import GaussianProcessRegressor\n",
        "from sklearn.gaussian_process.kernels import RBF, WhiteKernel, ConstantKernel as C\n",
        "\n",
        "# -----------------------------\n",
        "# 1. PROXY BAND SELECTION\n",
        "# -----------------------------\n",
        "def proxy_bands(groups):\n",
        "    out = []\n",
        "    for g in groups:\n",
        "        out.extend(\n",
        "            sorted(groups_orig[g], key=lambda b: mi[b], reverse=True)[:3]\n",
        "        )\n",
        "    return sorted(set(out))[:TARGET_K]\n",
        "\n",
        "# -----------------------------\n",
        "# 2. FITNESS FUNCTION (LINEAR SVM)\n",
        "# -----------------------------\n",
        "def eval_group_mask(mask):\n",
        "    groups = [i for i, v in enumerate(mask) if v]\n",
        "    if not groups:\n",
        "        return 1.0  # worst loss\n",
        "\n",
        "    bands = proxy_bands(groups)\n",
        "\n",
        "    clf = make_pipeline(\n",
        "        StandardScaler(),\n",
        "        LinearSVC(\n",
        "            C=0.1,\n",
        "            max_iter=3000,\n",
        "            dual=False\n",
        "        )\n",
        "    )\n",
        "\n",
        "    acc = cross_val_score(\n",
        "        clf,\n",
        "        X_train[:, bands],\n",
        "        y_train,\n",
        "        cv=CV_FOLDS,\n",
        "        scoring=\"accuracy\",\n",
        "        n_jobs=-1\n",
        "    ).mean()\n",
        "\n",
        "    return 1.0 - acc  # BO minimizes\n",
        "\n",
        "# -----------------------------\n",
        "# 3. RANDOM GROUP MASK GENERATOR\n",
        "# -----------------------------\n",
        "def random_group_masks(N, k):\n",
        "    masks = []\n",
        "    for _ in range(N):\n",
        "        m = np.zeros(n_groups, dtype=int)\n",
        "        m[np.random.choice(n_groups, k, replace=False)] = 1\n",
        "        masks.append(m)\n",
        "    return masks\n",
        "\n",
        "# -----------------------------\n",
        "# 4. LEVEL-1 BAYESIAN OPTIMIZATION\n",
        "# -----------------------------\n",
        "K_g = min(6, max(3, n_groups // 2))\n",
        "obs_X, obs_y = [], []\n",
        "\n",
        "# ---- Initial random evaluations\n",
        "for m in random_group_masks(GROUP_INIT, K_g):\n",
        "    obs_X.append(m.astype(float))\n",
        "    obs_y.append(eval_group_mask(m))\n",
        "\n",
        "# ---- Gaussian Process surrogate\n",
        "kernel = C(1.0) * RBF(length_scale=1.0) + WhiteKernel(noise_level=1e-3)\n",
        "gpr = GaussianProcessRegressor(\n",
        "    kernel=kernel,\n",
        "    normalize_y=True,\n",
        "    random_state=0\n",
        ")\n",
        "\n",
        "# ---- Expected Improvement\n",
        "def expected_improvement(mu, sigma, best):\n",
        "    Z = (best - mu) / (sigma + 1e-9)\n",
        "    return (best - mu) * norm.cdf(Z) + sigma * norm.pdf(Z)\n",
        "\n",
        "# ---- BO loop\n",
        "for _ in range(GROUP_BO_ITERS):\n",
        "    gpr.fit(np.array(obs_X), np.array(obs_y))\n",
        "\n",
        "    # Reduced candidates for speed\n",
        "    cands = random_group_masks(300, K_g)\n",
        "    X_cand = np.array(cands, dtype=float)\n",
        "\n",
        "    mu, sigma = gpr.predict(X_cand, return_std=True)\n",
        "    ei = expected_improvement(mu, sigma, min(obs_y))\n",
        "\n",
        "    idx = np.argmax(ei)\n",
        "    best_cand = X_cand[idx]\n",
        "\n",
        "    obs_X.append(best_cand)\n",
        "    obs_y.append(eval_group_mask(best_cand))\n",
        "\n",
        "# -----------------------------\n",
        "# 5. BEST GROUP SELECTION\n",
        "# -----------------------------\n",
        "best_group_mask = obs_X[np.argmin(obs_y)]\n",
        "best_groups = [i for i, v in enumerate(best_group_mask) if v]\n",
        "\n",
        "print(\"Selected groups (Level-1):\", best_groups)\n"
      ]
