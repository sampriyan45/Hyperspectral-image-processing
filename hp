        "plt.plot(best_l1, marker=\"o\")\n",
        "plt.title(\"Level-1 GH-BO Convergence\")\n",
        "plt.xlabel(\"Iteration\")\n",
        "plt.ylabel(\"Best Loss\")\n",
        "plt.grid()\n",
        "plt.show()\n",
        "\n",
        "# ============================================================\n",
        "# 5. LEVEL-2 GH-BO (BAND SELECTION)\n",
        "# ============================================================\n",
        "\n",
        "band_pool = sorted({b for g in best_groups for b in groups_orig[g]})\n",
        "print(\"Band pool size:\", len(band_pool))\n",
        "\n",
        "BAND_INIT = 15\n",
        "BAND_BO_ITERS = 15\n",
        "\n",
        "def random_band_masks(N, k):\n",
        "    masks = []\n",
        "    for _ in range(N):\n",
        "        m = np.zeros(len(band_pool), dtype=int)\n",
        "        m[np.random.choice(len(band_pool), k, replace=False)] = 1\n",
        "        masks.append(m)\n",
        "    return masks\n",
        "\n",
        "def eval_band_mask(mask):\n",
        "    idx = np.where(mask)[0]\n",
        "    if len(idx) == 0:\n",
        "        return 1.0\n",
        "\n",
        "    bands = [band_pool[i] for i in idx]\n",
        "\n",
        "    clf = make_pipeline(\n",
        "        StandardScaler(),\n",
        "        LinearSVC(C=0.1, max_iter=3000, dual=False)\n",
        "    )\n",
        "\n",
        "    acc = cross_val_score(\n",
        "        clf, X_train[:, bands], y_train,\n",
        "        cv=CV_FOLDS, scoring=\"accuracy\", n_jobs=-1\n",
        "    ).mean()\n",
        "\n",
        "    return 1.0 - acc\n",
        "\n",
        "obs_X2, obs_y2 = [], []\n",
        "\n",
        "for m in random_band_masks(BAND_INIT, TARGET_K):\n",
        "    obs_X2.append(m.astype(float))\n",
        "    obs_y2.append(eval_band_mask(m))\n",
        "\n",
        "gpr2 = GaussianProcessRegressor(\n",
        "    kernel=C(1.0) * RBF() + WhiteKernel(1e-3),\n",
        "    normalize_y=True\n",
        ")\n",
        "\n",
        "best_l2 = []\n",
        "\n",
        "for it in range(BAND_BO_ITERS):\n",
        "    gpr2.fit(np.array(obs_X2), np.array(obs_y2))\n",
        "    cands = random_band_masks(150, TARGET_K)\n",
        "    mu, sigma = gpr2.predict(np.array(cands), return_std=True)\n",
        "\n",
        "    Z = (min(obs_y2) - mu) / (sigma + 1e-9)\n",
        "    ei = (min(obs_y2) - mu) * norm.cdf(Z) + sigma * norm.pdf(Z)\n",
        "\n",
        "    idx = np.argmax(ei)\n",
        "    obs_X2.append(cands[idx].astype(float))\n",
        "    obs_y2.append(eval_band_mask(cands[idx]))\n",
        "\n",
        "    best_l2.append(min(obs_y2))\n",
        "    print(f\"L2 Iter {it+1}, Best Loss: {best_l2[-1]:.4f}\")\n",
        "\n",
        "best_band_mask = obs_X2[np.argmin(obs_y2)]\n",
        "final_bands = [band_pool[i] for i in np.where(best_band_mask)[0]]\n",
        "\n",
        "plt.figure()\n",
        "plt.plot(best_l2, marker=\"s\", color=\"orange\")\n",
        "plt.title(\"Level-2 GH-BO Convergence\")\n",
        "plt.xlabel(\"Iteration\")\n",
        "plt.ylabel(\"Best Loss\")\n",
        "plt.grid()\n",
        "plt.show()\n",
        "\n",
        "# ============================================================\n",
        "# 6. FINAL CLASSIFICATION + METRICS\n",
