        "    bands = []\n",
        "    remaining = TARGET_K\n",
        "    groups_perm = np.random.permutation(best_groups)\n",
        "\n",
        "    for g in groups_perm:\n",
        "        gb = groups_orig[g]\n",
        "        size = max(1, remaining // len(groups_perm))\n",
        "        size = min(size, len(gb), remaining)\n",
        "        bands.extend(np.random.choice(gb, size=size, replace=False))\n",
        "        remaining -= size\n",
